{
  "manifest_version": 3,
  "name": "Verid — Fraud Detection",
  "version": "1.0.0",
  "description": "Detects fraudulent marketplace listings before you pay.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.jumia.com.ng/*",
    "*://*.jumia.com/*",
    "*://*.temu.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.jumia.com.ng/*",
        "*://*.jumia.com/*",
        "*://*.temu.com/*"
      ],
      "js": ["dist/content.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_title": "Verid"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
