# Frontend env — copy to .env.local and fill in. .env.local is gitignored.
#
# Client-safe (shipped to the browser). These are the anon URL + key from your
# Supabase project → Settings → API. The anon key is public by design; RLS is
# what protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Backend URL for the Verid analyze call (Phase 3). Defaults to local backend.
NEXT_PUBLIC_VERID_API_URL=http://localhost:3001

# SERVER-ONLY. Used exclusively by scripts/seed.ts to create demo accounts and
# insert the three demo listings. NEVER referenced by app code, NEVER prefixed
# with NEXT_PUBLIC_ (that would leak it to the browser). Supabase → Settings →
# API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
